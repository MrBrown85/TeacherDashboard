    "course_name": "Remotely Operated Vehicles and Drones 12",
    "short_tag": "ROV12",
    "ministry_url": "https://curriculum.gov.bc.ca/curriculum/adst/12/remotely-operated-vehicles-drones",
    "description": "Students explore the design, programming, and operation of remotely operated vehicles (ROVs) and unmanned aerial vehicles (drones). This course emphasizes engineering design, autonomous systems, and real-world applications in exploration and monitoring.",
    "general_description": "ROV and drone design, programming, operation, and industry applications.",
    "cross_curricular_connections": [
      "Robotics 12",
      "Computer Programming 12",
      "Mechatronics 12"
    ],
    "first_peoples_principles": true
  },
  "big_ideas": [
    {
      "id": "bi_rov12_1",
      "statement": "Remotely operated vehicles extend human capability to explore and interact with environments beyond human reach",
      "elaboration": "ROVs and drones enable inspection, monitoring, and data collection in hazardous, distant, or inaccessible locations."
    },
    {
      "id": "bi_rov12_2",
      "statement": "ROV and drone design requires integration of mechanical, electrical, and software systems in compact form",
      "elaboration": "Compact autonomous systems demand careful design balancing capability, weight, power, and reliability."
    },
    {
      "id": "bi_rov12_3",
      "statement": "Programming autonomous behavior requires algorithmic thinking and sensor integration",
      "elaboration": "Autonomous systems must process sensor data and make decisions to accomplish missions independently."
    },
    {
      "id": "bi_rov12_4",
      "statement": "ROVs and drones have diverse applications in exploration, industry, emergency response, and research",
      "elaboration": "These technologies serve many fields from underwater archaeology to agricultural monitoring to disaster response."
    }
  ],
