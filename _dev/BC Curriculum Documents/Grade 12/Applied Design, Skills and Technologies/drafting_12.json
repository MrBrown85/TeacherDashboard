    "course_name": "Drafting 12",
    "short_tag": "DRAFT12",
    "ministry_url": "https://curriculum.gov.bc.ca/curriculum/adst/12/drafting",
    "description": "Students master advanced computer-aided design (CAD) and technical drawing skills for architectural and engineering applications. This course emphasizes 3D modeling, construction documentation, engineering drawings, and professional drafting standards.",
    "general_description": "Advanced CAD, 3D modeling, construction documentation, and engineering drawings.",
    "cross_curricular_connections": [
      "Engineering 12",
      "Housing and Living Environments 12",
      "Mathematics 12"
    ],
    "first_peoples_principles": true
  },
  "big_ideas": [
    {
      "id": "bi_draft12_1",
      "statement": "Technical drawings communicate design intent precisely using standardized conventions and symbols",
      "elaboration": "Accurate drafting enables others to understand and construct designs according to specifications."
    },
    {
      "id": "bi_draft12_2",
      "statement": "CAD technology enables efficient design creation, modification, and documentation",
      "elaboration": "Computer-aided design allows designers to explore alternatives, make precise changes, and generate comprehensive documentation."
    },
    {
      "id": "bi_draft12_3",
      "statement": "3D modeling provides visualization and enables analysis of designs before construction",
      "elaboration": "Three-dimensional representation helps identify conflicts, optimize designs, and communicate concepts."
    },
    {
      "id": "bi_draft12_4",
      "statement": "Professional drafting requires knowledge of standards, conventions, and industry best practices",
      "elaboration": "Drafters must follow established standards and communicate effectively with architects, engineers, and builders."
    }
  ],
