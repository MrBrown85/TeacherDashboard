  "big_ideas": [
    {
      "id": "bi_rob12_1",
      "statement": "Robotics integrates mechanical design, electrical systems, and intelligent programming to create autonomous agents",
      "elaboration": "Robots require coordination of multiple systems to perceive, decide, and act in their environment."
    },
    {
      "id": "bi_rob12_2",
      "statement": "Autonomous systems can be programmed to accomplish complex tasks through perception, logic, and control",
      "elaboration": "Robot behavior emerges from sensor inputs, programmed logic, and actuator control."
    },
    {
      "id": "bi_rob12_3",
      "statement": "Competition and challenges drive innovation and provide context for skill development",
      "elaboration": "Robot competitions provide realistic problem-solving scenarios and motivate technical excellence."
    },
    {
      "id": "bi_rob12_4",
      "statement": "Robotics careers offer diverse opportunities from manufacturing to research to entertainment",
      "elaboration": "Robotics skills are valued across many industries and research disciplines."
    }
  ],
