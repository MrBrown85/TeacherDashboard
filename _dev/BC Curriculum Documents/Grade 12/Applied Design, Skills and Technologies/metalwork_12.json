  "big_ideas": [
    {
      "id": "bi_metal12_1",
      "statement": "Metalworking transforms raw metals into functional structures and components through deliberate processes",
      "elaboration": "Metalworkers use heating, forming, and joining techniques to create durable structures."
    },
    {
      "id": "bi_metal12_2",
      "statement": "Structural integrity requires understanding material properties, design principles, and construction methods",
      "elaboration": "Well-designed and constructed metal structures distribute forces safely and reliably."
    },
    {
      "id": "bi_metal12_3",
      "statement": "Quality metal fabrication demands precision, skill, and attention to detail",
      "elaboration": "Professional metalwork achieves tight tolerances and high-quality finishes."
    },
    {
      "id": "bi_metal12_4",
      "statement": "Metalworking professionals combine technical skill, safety consciousness, and artistic appreciation",
      "elaboration": "Successful metalworking careers integrate technical mastery with safety awareness and quality standards."
    }
  ],
