  "content": {
    "areas": [
      {
        "name": "Lathe Operation and Turning",
        "raw": "Lathe Operation and Turning",
        "topics": [
          "Lathe types and components",
          "Setting up and adjusting lathes",
          "Turning, facing, and boring",
          "Threading and taper cutting",
          "Tool selection and optimization"
        ]
      },
      {
        "name": "Milling and CNC Machines",
        "raw": "Milling and CNC Machines",
        "topics": [
          "Vertical and horizontal mills",
          "Setting up work and fixtures",
          "Face milling and slotting",
          "Drilling and boring operations",
          "CNC mill operation and basics"
        ]
      },
      {
        "name": "Welding Processes and Techniques",
        "raw": "Welding Processes and Techniques",
        "topics": [
          "SMAW, GMAW, FCAW, and GTAW processes",
          "Joint preparation and fitup",
          "Welding positions and techniques",
          "Thermal effects and distortion",
          "Certification and quality standards"
        ]
      },
      {
        "name": "Precision and Quality Control",
        "raw": "Precision and Quality Control",
        "topics": [
          "Measurement instruments and techniques",
          "Tolerance and specification interpretation",
          "Quality inspection procedures",
          "Nondestructive testing basics",
          "Documentation and verification"
        ]
      }
