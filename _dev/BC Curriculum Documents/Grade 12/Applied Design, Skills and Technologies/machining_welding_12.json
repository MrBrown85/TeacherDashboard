    "course_name": "Machining and Welding 12",
    "short_tag": "MACHW12",
    "ministry_url": "https://curriculum.gov.bc.ca/curriculum/adst/12/machining-welding",
    "description": "Students develop advanced machining and welding skills including lathe and mill operation, welding certifications, precision measurement, and metalwork techniques. This course prepares students for trades certifications and careers in fabrication and machining.",
    "general_description": "Lathe and mill operation, welding certifications, precision measurement, and metalwork.",
    "cross_curricular_connections": [
      "Art Metal and Jewellery 12",
      "Engineering 12"
    ],
    "first_peoples_principles": true
  },
  "big_ideas": [
    {
      "id": "bi_machw12_1",
      "statement": "Precision machining transforms raw materials into finished components meeting exact specifications",
      "elaboration": "Machinists use machine tools and precision measurement to create parts that fit and function correctly."
    },
    {
      "id": "bi_machw12_2",
      "statement": "Welding joins metals through controlled heat and material processes creating strong bonds",
      "elaboration": "Welders must understand materials and processes to create reliable, high-quality joints."
    },
    {
      "id": "bi_machw12_3",
      "statement": "Precision measurement ensures products meet specifications and function as designed",
      "elaboration": "Accurate measurement is essential to verifying that components are made correctly."
    },
    {
      "id": "bi_machw12_4",
      "statement": "Professional machining and welding require safety consciousness, skill, and quality standards",
      "elaboration": "Successful trades careers combine technical mastery with safety awareness and professional practices."
    }
  ],
