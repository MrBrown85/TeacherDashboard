  "big_ideas": [
    {
      "id": "bi_wood12_1",
      "statement": "Woodworking transforms raw lumber into functional and beautiful objects through skill and craftsmanship",
      "elaboration": "Quality woodworking combines an understanding of wood properties with precise technique."
    },
    {
      "id": "bi_wood12_2",
      "statement": "Project planning and costing ensure woodworking ventures are feasible and profitable",
      "elaboration": "Professional woodworkers manage materials, time, and expenses to deliver value to customers."
    },
    {
      "id": "bi_wood12_3",
      "statement": "Industry-standard finishing creates durable, beautiful surfaces protecting wood while enhancing appearance",
      "elaboration": "Quality finishing requires knowledge of products, techniques, and proper application."
    },
    {
      "id": "bi_wood12_4",
      "statement": "Successful woodworking careers integrate technical skill, design sense, and business acumen",
      "elaboration": "Professional woodworkers combine craftsmanship with marketing and customer service skills."
    }
  ],
