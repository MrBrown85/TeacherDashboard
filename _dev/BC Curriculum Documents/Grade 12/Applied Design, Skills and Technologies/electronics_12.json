    "course_name": "Electronics 12",
    "short_tag": "ELEC12",
    "ministry_url": "https://curriculum.gov.bc.ca/curriculum/adst/12/electronics",
    "description": "Students develop advanced electronics knowledge encompassing microcontroller programming, programmable logic controllers (PLCs), industrial automation, and practical circuit design. This course prepares students for careers in industrial electronics and automation.",
    "general_description": "Advanced electronics, microcontrollers, PLC programming, and industrial automation applications.",
    "cross_curricular_connections": [
      "Computer Programming 12",
      "Automotive Technology 12"
    ],
    "first_peoples_principles": true
  },
  "big_ideas": [
    {
      "id": "bi_elec12_1",
      "statement": "Electronics enables automation and control of systems through integrated circuits and programmable devices",
      "elaboration": "Microcontrollers and PLCs provide flexible platforms for controlling and monitoring industrial and consumer systems."
    },
    {
      "id": "bi_elec12_2",
      "statement": "Circuit design requires understanding of components, circuit theory, and practical engineering constraints",
      "elaboration": "Effective circuits balance theoretical principles with practical considerations of availability, cost, and reliability."
    },
    {
      "id": "bi_elec12_3",
      "statement": "Industrial automation improves efficiency, safety, and consistency through automated control systems",
      "elaboration": "Automated systems require careful design, programming, and integration to function reliably in industrial environments."
    },
    {
      "id": "bi_elec12_4",
      "statement": "Electronics professionals require safety consciousness, troubleshooting skills, and continuous learning",
      "elaboration": "Rapid technology changes require electronics professionals to continuously update their knowledge and skills."
    }
  ],
