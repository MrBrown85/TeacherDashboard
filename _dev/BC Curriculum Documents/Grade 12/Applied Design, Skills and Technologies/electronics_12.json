  "content": {
    "areas": [
      {
        "name": "Circuit Theory and Design",
        "raw": "Circuit Theory and Design",
        "topics": [
          "Voltage, current, and resistance",
          "AC and DC circuit analysis",
          "Passive components and their applications",
          "Active components and amplification",
          "Power supply design and regulation"
        ]
      },
      {
        "name": "Microcontroller Programming and Applications",
        "raw": "Microcontroller Programming and Applications",
        "topics": [
          "Microcontroller architecture and operation",
          "Programming languages and environments",
          "I/O and peripheral interfacing",
          "Interrupt handling and timing",
          "Sensor integration and data processing"
        ]
      },
      {
        "name": "Industrial Automation and PLC Systems",
        "raw": "Industrial Automation and PLC Systems",
        "topics": [
          "PLC architecture and operation",
          "Ladder logic programming",
          "Input/output modules",
          "Data handling and logic functions",
          "HMI and communication interfaces"
        ]
      },
      {
        "name": "Advanced Applications and Professional Practice",
        "raw": "Advanced Applications and Professional Practice",
        "topics": [
          "Motor control and drives",
          "Safety systems and fail-safes",
          "Industrial communication protocols",
          "System integration and testing",
          "Troubleshooting and maintenance"
        ]
      }
    ]
