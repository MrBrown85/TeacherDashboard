    "ministry_url": "https://curriculum.gov.bc.ca/curriculum/adst/12/engine-drivetrain",
    "description": "Students develop specialized knowledge of engine systems, drivetrain components, and automotive performance. This course covers engine rebuilding, transmission systems, differential operation, and performance tuning techniques.",
    "general_description": "Engine rebuilding, drivetrain systems, transmission overhaul, and performance tuning.",
    "cross_curricular_connections": [
      "Automotive Technology 12",
      "Mechanical Engineering"
    ],
    "first_peoples_principles": true
  },
  "big_ideas": [
    {
      "id": "bi_edt12_1",
      "statement": "Engine systems convert fuel energy into mechanical motion through precisely coordinated processes",
      "elaboration": "Understanding engine operation requires knowledge of thermodynamics, mechanics, and system interactions."
    },
    {
      "id": "bi_edt12_2",
      "statement": "Drivetrain components transmit engine power to wheels efficiently while accommodating varied driving conditions",
      "elaboration": "Drivetrains integrate multiple systems to deliver power, manage torque, and maintain stability."
    },
    {
      "id": "bi_edt12_3",
      "statement": "Engine rebuilding requires precision, knowledge of clearances, and quality assembly practices",
      "elaboration": "Proper engine rebuilding ensures reliability, performance, and longevity of rebuilt engines."
    },
    {
      "id": "bi_edt12_4",
      "statement": "Performance optimization balances power, efficiency, reliability, and legal compliance",
      "elaboration": "Performance tuning requires understanding of engine systems and careful testing to achieve safe, effective modifications."
    }
  ],
