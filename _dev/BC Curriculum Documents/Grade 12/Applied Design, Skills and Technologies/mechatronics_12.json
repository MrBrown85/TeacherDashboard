  "big_ideas": [
    {
      "id": "bi_mech12_1",
      "statement": "Mechatronic systems combine mechanical design, electrical control, and software to create intelligent machines",
      "elaboration": "Effective mechatronic design requires understanding and integrating multiple engineering disciplines."
    },
    {
      "id": "bi_mech12_2",
      "statement": "Automation improves efficiency, consistency, and capability beyond what humans or machines alone can achieve",
      "elaboration": "Automated systems perform repetitive, dangerous, or precise tasks more effectively than manual operation."
    },
    {
      "id": "bi_mech12_3",
      "statement": "Mechatronic systems require careful design and integration to function reliably in real-world conditions",
      "elaboration": "Successful systems balance mechanical robustness, electrical reliability, and algorithmic sophistication."
    },
    {
      "id": "bi_mech12_4",
      "statement": "Mechatronics professionals require knowledge across multiple disciplines and systems-level thinking",
      "elaboration": "Mechatronics careers demand understanding of how mechanical, electrical, and software systems interact."
    }
  ],
