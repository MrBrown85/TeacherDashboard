  "big_ideas": [
    {
      "id": "bi_eng12_1",
      "statement": "Engineering applies scientific principles and creative problem-solving to design solutions for real-world challenges",
      "elaboration": "Engineers use systematic design processes, analysis, and testing to develop functional, safe, and efficient solutions."
    },
    {
      "id": "bi_eng12_2",
      "statement": "Capstone projects require planning, design, prototyping, testing, and communication of solutions",
      "elaboration": "Complex engineering problems demand systematic approaches, iteration, and comprehensive documentation."
    },
    {
      "id": "bi_eng12_3",
      "statement": "Structural analysis ensures designs are safe, efficient, and meet performance requirements",
      "elaboration": "Engineers must verify that designs can withstand expected loads and stresses."
    },
    {
      "id": "bi_eng12_4",
      "statement": "Professional engineering practice emphasizes safety, ethics, sustainability, and communication",
      "elaboration": "Engineers have responsibility to society to design safe products while considering environmental and social impacts."
    }
  ],
