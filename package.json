{
  "name": "teacher-dashboard",
  "version": "1.0.0",
  "description": "Standards-based gradebook for BC teachers",
  "private": true,
  "scripts": {
    "build": "bash scripts/build.sh",
    "build:e2e": "bash scripts/build-e2e.sh",
    "dev": "npx serve -l 8347",
    "dev:local": "node scripts/dev-local.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "format": "prettier --write '**/*.{js,css,html,json,md}'",
    "format:check": "prettier --check '**/*.{js,css,html,json,md}'"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "linkedom": "^0.18.12",
    "prettier": "^3.2.0",
    "vitest": "^1.6.0"
  }
}
