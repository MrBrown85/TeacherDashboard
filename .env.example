# Supabase Configuration
# Create a project at https://supabase.com
# Use ca-central-1 (Montreal) region for FOIPPA compliance

# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public key (found in Project Settings > API > anon/public)
SUPABASE_ANON_KEY=your-anon-key-here

# NOTE: Currently these values are hardcoded in gb-supabase.js (lines 6-7)
# as SUPABASE_URL and SUPABASE_KEY constants. The app reads them directly
# from the JS file, not from environment variables.
# This file exists for documentation and as a reference for deployment.
