# Supabase Configuration
# Create a project at https://supabase.com
# Use ca-central-1 (Montreal) region for FOIPPA compliance

# Your Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public key (found in Project Settings > API > anon/public)
SUPABASE_KEY=your-anon-key-here

# These values are injected at serve time by the Netlify edge function (netlify/edge-functions/inject-env.js)
# in production, or by scripts/dev-local.mjs when running `npm run dev:local`.
# For production: set SUPABASE_URL and SUPABASE_KEY in Netlify UI → Site settings → Environment variables.
# For local signed-in dev: copy this file to .env, fill in your values, then run:
#   npm run dev:local
